---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
}
const { title, description = "EpiFluid Lab — epigenomics and computational biology at Northwestern University Feinberg School of Medicine." } = Astro.props;
const fullTitle = title === 'Home' ? 'EpiFluid Lab' : `${title} | EpiFluid Lab`;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{fullTitle}</title>
  <link rel="icon" type="image/png" href="/images/logo.epifluidlab.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Merriweather:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-white text-gray-900 font-sans antialiased">
  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-100">
    <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center">
        <img src="/images/logo.epifluid.png" alt="EpiFluid Lab" class="h-10 w-auto object-contain" />
      </a>
      <div class="hidden md:flex items-center gap-1">
        {[
          { href: '/research', label: 'Research' },
          { href: '/publications', label: 'Publications' },
          { href: '/software', label: 'Software' },
          { href: '/team', label: 'Team' },
          { href: '/photos', label: 'Photos' },
          { href: '/contact', label: 'Contact' },
        ].map(({ href, label }) => (
          <a
            href={href}
            class="px-3 py-1.5 rounded-md text-sm font-medium text-gray-600 hover:text-nu-purple hover:bg-nu-ghost-soft transition-colors"
          >
            {label}
          </a>
        ))}
      </div>
      <!-- Mobile menu button (simple) -->
      <button id="menu-btn" class="md:hidden p-2 rounded-md text-gray-600 hover:bg-gray-100" aria-label="Menu">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </nav>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white px-6 py-3 flex flex-col gap-1">
      {[
        { href: '/research', label: 'Research' },
        { href: '/publications', label: 'Publications' },
        { href: '/team', label: 'Team' },
        { href: '/contact', label: 'Contact' },
      ].map(({ href, label }) => (
        <a href={href} class="py-2 text-sm font-medium text-gray-700 hover:text-nu-purple">{label}</a>
      ))}
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="border-t border-gray-200 bg-gray-100">
    <div class="max-w-6xl mx-auto px-6 py-10 flex flex-col md:flex-row justify-between items-start gap-6">
      <div>
        <div class="mb-2">
          <img src="/images/logo.epifluid.png" alt="EpiFluid Lab" class="h-10 w-auto object-contain" />
        </div>
        <p class="text-sm text-gray-500 max-w-xs">Simpson Querrey Institute for Epigenetics<br/>Northwestern University Feinberg School of Medicine</p>
      </div>
      <div class="flex gap-4 items-center">
        <a href="mailto:yaping@northwestern.edu" class="text-gray-400 hover:text-nu-purple transition-colors" title="Email">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
        <a href="https://github.com/epifluidlab" target="_blank" rel="noopener" class="text-gray-400 hover:text-nu-purple transition-colors" title="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        </a>
        <a href="https://twitter.com/yapingliu" target="_blank" rel="noopener" class="text-gray-400 hover:text-nu-purple transition-colors" title="X / Twitter">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://orcid.org/0000-0003-4165-7693" target="_blank" rel="noopener" class="text-gray-400 hover:text-nu-purple transition-colors" title="ORCID">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 3.788-2.269 3.788-3.722 0-2.016-1.116-3.722-3.984-3.722h-2.1z"/></svg>
        </a>
      </div>
    </div>
    <div class="border-t border-gray-200 py-4 text-center text-xs text-gray-400">
      &copy; {new Date().getFullYear()} EpiFluid Lab, Northwestern University
    </div>
  </footer>

  <script>
    document.getElementById('menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
  </script>
</body>
</html>
