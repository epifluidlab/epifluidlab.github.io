---
import Layout from '../layouts/Layout.astro';
import { tools } from '../data/tools';
---
<Layout title="Software" description="Open-source software and resources from the EpiFluid Lab at Northwestern University.">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Software</h1>

    <div class="grid md:grid-cols-2 gap-6">
      {tools.map((tool) => (
        <article class="rounded-xl border border-gray-200 overflow-hidden hover:border-nu-ghost hover:shadow-sm transition-all">
          {tool.image && (
            <div class="w-full bg-gray-50 border-b border-gray-100 flex items-center justify-center p-6">
              <img src={tool.image} alt={tool.name} class="max-h-80 w-full object-contain" />
            </div>
          )}
          <div class="p-6">
            <div class="flex flex-wrap gap-2 mb-3">
              {tool.tags.map((tag) => (
                <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-nu-ghost-soft text-nu-purple capitalize">{tag}</span>
              ))}
            </div>
            <h2 class="text-lg font-semibold text-gray-900 mb-1">{tool.name}</h2>
            <p class="text-sm font-medium text-nu-purple mb-2">{tool.description}</p>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">{tool.details}</p>
            <div class="flex flex-wrap gap-3">
              {tool.links.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-lg border border-gray-200 text-gray-600 hover:border-nu-light hover:text-nu-purple transition-colors"
                >
                  {link.label === 'GitHub' && (
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                  )}
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>
